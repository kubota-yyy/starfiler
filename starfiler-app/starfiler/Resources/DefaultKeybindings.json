{
  "bindings": {
    "normal": {
      "j": "cursorDown",
      "k": "cursorUp",
      "h": "cursorLeft",
      "l": "cursorRight",
      "g g": "goToTop",
      "G": "goToBottom",
      "Ctrl-u": "pageUp",
      "Ctrl-d": "pageDown",
      "Return": "enterDirectory",
      "Backspace": "goToParent",
      "H": "goBack",
      "L": "goForward",
      "Space": "toggleMark",
      "v": "enterVisualMode",
      "y": "copy",
      "p": "paste",
      "d d": "delete",
      "c w": "rename",
      "/": "enterFilterMode",
      "Tab": "switchPane",
      "Ctrl-p": "togglePreview",
      "Ctrl-b": "toggleSidebar",
      "Ctrl-1": "toggleLeftPane",
      "Ctrl-2": "toggleRightPane",
      "Ctrl-3": "toggleSinglePane",
      "Ctrl-m": "toggleMediaMode",
      "Ctrl-Shift-m": "toggleMediaRecursive",
      "Ctrl-f": "enterSpotlightSearch",
      ".": "toggleHiddenFiles",
      "u": "undo",
      "b": "openBookmarkSearch",
      "Ctrl-r": "openHistory",
      "B": "addBookmark",
      "r": "refresh",
      "o": "openFile",
      "O": "openFileInFinder",
      "R": "batchRename",
      "S": "syncPanes",
      "q": "quit"
    },
    "visual": {
      "j": "cursorDown",
      "k": "cursorUp",
      "Escape": "exitVisualMode",
      "y": "copy",
      "d": "delete"
    },
    "filter": {
      "Escape": "clearFilter",
      "Return": "clearFilter"
    }
  }
}
