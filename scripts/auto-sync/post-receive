#!/usr/bin/env bash
# post-receive — gitサーバーに設置するフック
# push時にpush元以外のMacへ自動pullを実行

# config.shのパス（gitサーバー上の絶対パス）
CONFIG_PATH="/Users/harry/git-server/starfiler.git/hooks/auto-sync-config.sh"

if [ ! -f "$CONFIG_PATH" ]; then
  echo "auto-sync: config not found at $CONFIG_PATH"
  exit 0
fi

source "$CONFIG_PATH"

# push元のIPを取得（SSH_CLIENT="IP PORT PORT"）
PUSHER_IP=""
if [ -n "${SSH_CLIENT:-}" ]; then
  PUSHER_IP=$(echo "$SSH_CLIENT" | awk '{print $1}')
fi

# GitHubリモートURL（bare repoからGitHubへも自動push）
GITHUB_REMOTE="git@github.com:YutakaKubota/starfiler.git"

# mainブランチへのpushかチェック
while read oldrev newrev refname; do
  if [ "$refname" = "refs/heads/main" ]; then
    # GitHubへ自動ミラー push
    git push "$GITHUB_REMOTE" main >> /tmp/auto-sync-post-receive.log 2>&1 &

    for target in "${SYNC_TARGETS[@]}"; do
      IFS=':' read -r ip user repo_path <<< "$target"

      # push元自身はスキップ
      if [ "$ip" = "$PUSHER_IP" ]; then
        continue
      fi

      # バックグラウンドでSSH経由のauto-pullを実行
      ssh -o ConnectTimeout="${SSH_TIMEOUT:-5}" \
          -o StrictHostKeyChecking=no \
          -o BatchMode=yes \
          "${user}@${ip}" \
          "cd ${repo_path} && bash scripts/auto-sync/auto-pull.sh" \
          >> /tmp/auto-sync-post-receive.log 2>&1 &
    done
  fi
done

# バックグラウンドジョブの完了を待たない（pushの応答をブロックしない）
exit 0
